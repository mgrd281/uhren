generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AccessRequest {
  id          String   @id @default(cuid())
  email       String
  name        String?
  image       String?
  googleUid   String
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  city        String?
  country     String?
  ip          String?
  userAgent   String?
  fingerprint String?
  role        String   @default("viewer")

  @@index([createdAt])
  @@index([fingerprint])
  @@index([googleUid])
  @@index([ip])
  @@index([status])
}

model AuthorizedUser {
  id        String   @id @default("owner")
  googleUid String   @unique
  email     String
  name      String?
  image     String?
  createdAt DateTime @default(now())
}

model InventoryMovement {
  id          String       @id @default(cuid())
  productId   String
  type        MovementType
  quantity    Int
  referenceId String?
  note        String?
  createdAt   DateTime     @default(now())
  product     Product      @relation(fields: [productId], references: [id])

  @@index([createdAt])
  @@index([productId])
  @@index([type])
}

model Product {
  id                String              @id @default(cuid())
  name              String
  brand             String
  model             String
  sku               String              @unique
  category          String
  color             String
  description       String
  costPrice         Float
  salePriceExpected Float
  quantity          Int                 @default(0)
  lowStockThreshold Int                 @default(2)
  status            StockStatus         @default(IN_STOCK)
  mainImage         String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  notes             String?
  ebayStatus        String              @default("")
  shopifyListed     Boolean             @default(false)
  storageLocation   String?
  storagePhoto      String?
  kartonAnzahl      Int                 @default(0)
  hasBox            Boolean             @default(false)
  inventoryMoves    InventoryMovement[]
  galleryImages     ProductImage[]
  sales             Sale[]

  @@index([brand])
  @@index([createdAt])
  @@index([status])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  imageUrl  String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Sale {
  id              String   @id @default(cuid())
  productId       String
  quantitySold    Int
  salePrice       Float
  totalAmount     Float
  customerName    String?
  invoiceNumber   String?
  soldAt          DateTime @default(now())
  notes           String?
  createdAt       DateTime @default(now())
  paymentMethod   String?
  shippingCost    Float    @default(0)
  marketplace     String?
  shippingCarrier String?
  trackingNumber  String?
  packagingCost   Float    @default(0)
  shippingAddress String?
  product     Product  @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([soldAt])
}

model StoreSettings {
  id           String   @id @default("default")
  storeName    String   @default("Luxusuhren Verwaltung")
  locale       String   @default("de")
  currencyCode String   @default("EUR")
  rtlEnabled   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  password     String
  totpSecret   String?
}

enum MovementType {
  ADD
  SALE
  ADJUSTMENT
  SHIPPING
}

enum StockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum StockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
}

enum MovementType {
  ADD
  SALE
  ADJUSTMENT
  SHIPPING
}

model Product {
  id                String              @id @default(cuid())
  name              String
  brand             String
  model             String
  sku               String              @unique
  category          String
  color             String
  description       String
  costPrice         Float
  salePriceExpected Float
  quantity          Int                 @default(0)
  lowStockThreshold Int                 @default(2)
  status            StockStatus         @default(IN_STOCK)
  mainImage         String?
  ebayStatus        String              @default("Nicht gepostet")
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  notes             String?
  galleryImages     ProductImage[]
  sales             Sale[]
  inventoryMoves    InventoryMovement[]

  @@index([brand])
  @@index([status])
  @@index([createdAt])
}

model ProductImage {
  id              String   @id @default(cuid())
  productId       String
  imageUrl        String
  shopifyImageId  String?  @unique
  isPrimary       Boolean  @default(false)
  createdAt       DateTime @default(now())
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Sale {
  id            String   @id @default(cuid())
  productId     String
  quantitySold  Int
  salePrice     Float
  totalAmount   Float
  customerName  String?
  invoiceNumber String?
  paymentMethod String?
  shippingCost  Float    @default(0)
  soldAt        DateTime @default(now())
  notes         String?
  createdAt     DateTime @default(now())
  product       Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([soldAt])
}

model InventoryMovement {
  id          String       @id @default(cuid())
  productId   String
  type        MovementType
  quantity    Int
  referenceId String?
  note        String?
  createdAt   DateTime     @default(now())
  product     Product      @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([type])
  @@index([createdAt])
}

model StoreSettings {
  id           String   @id @default("default")
  storeName    String   @default("Luxusuhren Verwaltung")
  locale       String   @default("de")
  currencyCode String   @default("EUR")
  rtlEnabled   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
